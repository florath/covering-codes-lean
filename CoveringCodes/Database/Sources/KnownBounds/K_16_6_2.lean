private def highRepairQuad (s : Fin 512) : Quad6 :=
  unpackQuad (packedHighRepairQuads.getD s.val 51)

private theorem highRepairQuad_distinct :
    ∀ s : Fin 512,
      let q := highRepairQuad s
      q.a ≠ q.b ∧ q.a ≠ q.c ∧ q.a ≠ q.d ∧
        q.b ≠ q.c ∧ q.b ≠ q.d ∧ q.c ≠ q.d := by
  native_decide

set_option maxRecDepth 20000 in
set_option maxHeartbeats 8000000 in
private theorem highRepair_quad_spec :
    ∀ x : QaryWord 8 6,
      let q := highRepairQuad (highSyndrome x)
      x q.a = highRepair x q.a ∧ x q.b = highRepair x q.b ∧
        x q.c = highRepair x q.c ∧ x q.d = highRepair x q.d := by
  native_decide

private def bitFromPacked (value place : Nat) : Fin 2 :=
  ⟨(value / place) % 2, by omega⟩

private def packedLowRows : Array Nat := #[
  1, 2, 4, 8, 15, 16, 23, 27, 29, 30, 32, 39, 43, 45, 46, 51, 53, 54, 57,
  58, 60
]

private def lowRow (idx : Fin 21) : QaryWord 2 6 :=
  let value := packedLowRows.getD idx.val 1
  fun position =>
    if position.val = 0 then bitFromPacked value 32
    else if position.val = 1 then bitFromPacked value 16
    else if position.val = 2 then bitFromPacked value 8
    else if position.val = 3 then bitFromPacked value 4
    else if position.val = 4 then bitFromPacked value 2
    else bitFromPacked value 1

private def firstMatchingLowRowIndex
    (q : Quad6) (a b c d : Fin 2) (idx fuel : Nat) : Fin 21 :=
  match fuel with
  | 0 => 0
  | fuel + 1 =>
      if hidx : idx < 21 then
        if lowRow ⟨idx, hidx⟩ q.a = a ∧ lowRow ⟨idx, hidx⟩ q.b = b ∧
            lowRow ⟨idx, hidx⟩ q.c = c ∧ lowRow ⟨idx, hidx⟩ q.d = d then
          ⟨idx, hidx⟩
        else
          firstMatchingLowRowIndex q a b c d (idx + 1) fuel
      else
        0

set_option maxRecDepth 10000 in
private theorem firstMatchingLowRowIndex_spec :
    ∀ s : Fin 512, ∀ a b c d : Fin 2,
      let q := highRepairQuad s
      let row := firstMatchingLowRowIndex q a b c d 0 21
      lowRow row q.a = a ∧ lowRow row q.b = b ∧
        lowRow row q.c = c ∧ lowRow row q.d = d := by
  native_decide

private def q16Center (highIdx : Fin 512) (lowIdx : Fin 21) : QaryWord 16 6 :=
  fun position => assembleSymbol (highCenter highIdx position) (lowRow lowIdx position)

private def q16Code : Finset (QaryWord 16 6) :=
  (Finset.univ : Finset (Fin 512 × Fin 21)).image (fun p => q16Center p.1 p.2)

private theorem q16Code_card :
    q16Code.card ≤ 10752 := by
  calc
    q16Code.card ≤ (Finset.univ : Finset (Fin 512 × Fin 21)).card := by
      simpa [q16Code] using
        Finset.card_image_le (s := (Finset.univ : Finset (Fin 512 × Fin 21)))
    _ = 10752 := by
      simp

private def q16RepairIndex (x : QaryWord 16 6) : Fin 512 × Fin 21 :=
  let highTarget : QaryWord 8 6 := fun position => highPart (x position)
  let syndrome := highSyndrome highTarget
  let highIdx := highRepairIndex highTarget
  let q := highRepairQuad syndrome
  let lowIdx := firstMatchingLowRowIndex q
    (lowPart (x q.a)) (lowPart (x q.b)) (lowPart (x q.c)) (lowPart (x q.d)) 0 21
  (highIdx, lowIdx)

private def q16Repair (x : QaryWord 16 6) : QaryWord 16 6 :=
  q16Center (q16RepairIndex x).1 (q16RepairIndex x).2

private theorem hammingDist_le_two_of_four_matches
    (x c : QaryWord 16 6) (i j k l : Fin 6)
    (hij : i ≠ j) (hik : i ≠ k) (hil : i ≠ l)
    (hjk : j ≠ k) (hjl : j ≠ l) (hkl : k ≠ l)
    (hi : x i = c i) (hj : x j = c j) (hk : x k = c k) (hl : x l = c l) :
    hammingDist x c ≤ 2 := by
  classical
  let bad : Finset (Fin 6) := Finset.univ.filter (fun position => x position ≠ c position)
  let matched : Finset (Fin 6) := {i, j, k, l}
  have hbad_subset : bad ⊆ Finset.univ \ matched := by
    intro position hposition
    have hne : x position ≠ c position := (Finset.mem_filter.mp hposition).2
    have hnot : position ∉ matched := by
      intro hmem
      simp [matched] at hmem
      rcases hmem with hmem | hmem | hmem | hmem
      · subst hmem
        exact hne hi
      · subst hmem
        exact hne hj
      · subst hmem
        exact hne hk
      · subst hmem
        exact hne hl
    exact Finset.mem_sdiff.mpr ⟨Finset.mem_univ position, hnot⟩
  have hmatched_card : matched.card = 4 := by
    simp [matched, hij, hik, hil, hjk, hjl, hkl]
  have hsdiff_card : (Finset.univ \ matched).card = 2 := by
    rw [Finset.card_sdiff_of_subset]
    · simp [hmatched_card]
    · intro position _
      exact Finset.mem_univ position
  calc
    hammingDist x c = bad.card := rfl
    _ ≤ (Finset.univ \ matched).card := Finset.card_le_card hbad_subset
    _ = 2 := hsdiff_card

set_option maxRecDepth 20000 in
private theorem q16Repair_mem (x : QaryWord 16 6) :
    q16Repair x ∈ q16Code := by
  exact Finset.mem_image.mpr ⟨q16RepairIndex x, Finset.mem_univ _, rfl⟩

private theorem q16Repair_dist (x : QaryWord 16 6) :
    hammingDist x (q16Repair x) ≤ 2 := by
  let highTarget : QaryWord 8 6 := fun position => highPart (x position)
  let syndrome := highSyndrome highTarget
  let highIdx := highRepairIndex highTarget
  let q := highRepairQuad syndrome
  let lowIdx := firstMatchingLowRowIndex q
    (lowPart (x q.a)) (lowPart (x q.b)) (lowPart (x q.c)) (lowPart (x q.d)) 0 21
  have hhigh := highRepair_quad_spec highTarget
  have hlow := firstMatchingLowRowIndex_spec syndrome
    (lowPart (x q.a)) (lowPart (x q.b)) (lowPart (x q.c)) (lowPart (x q.d))
  have hlow_a : lowRow lowIdx q.a = lowPart (x q.a) := by
    simpa [lowIdx, syndrome, q] using hlow.1
  have hlow_b : lowRow lowIdx q.b = lowPart (x q.b) := by
    simpa [lowIdx, syndrome, q] using hlow.2.1
  have hlow_c : lowRow lowIdx q.c = lowPart (x q.c) := by
    simpa [lowIdx, syndrome, q] using hlow.2.2.1
  have hlow_d : lowRow lowIdx q.d = lowPart (x q.d) := by
    simpa [lowIdx, syndrome, q] using hlow.2.2.2
  have hdistinct := highRepairQuad_distinct syndrome
  have hhigh_a : highCenter highIdx q.a = highPart (x q.a) := by
    simpa [highTarget, highRepair, highIdx, syndrome, q] using hhigh.1.symm
  have hhigh_b : highCenter highIdx q.b = highPart (x q.b) := by
    simpa [highTarget, highRepair, highIdx, syndrome, q] using hhigh.2.1.symm
  have hhigh_c : highCenter highIdx q.c = highPart (x q.c) := by
    simpa [highTarget, highRepair, highIdx, syndrome, q] using hhigh.2.2.1.symm
  have hhigh_d : highCenter highIdx q.d = highPart (x q.d) := by
    simpa [highTarget, highRepair, highIdx, syndrome, q] using hhigh.2.2.2.symm
  have ha : x q.a = q16Center highIdx lowIdx q.a := by
    simpa [q16Center, hhigh_a, hlow_a] using
      (assemble_high_low (x q.a)).symm
  have hb : x q.b = q16Center highIdx lowIdx q.b := by
    simpa [q16Center, hhigh_b, hlow_b] using
      (assemble_high_low (x q.b)).symm
  have hc : x q.c = q16Center highIdx lowIdx q.c := by
    simpa [q16Center, hhigh_c, hlow_c] using
      (assemble_high_low (x q.c)).symm
  have hd : x q.d = q16Center highIdx lowIdx q.d := by
    simpa [q16Center, hhigh_d, hlow_d] using
      (assemble_high_low (x q.d)).symm
  have hdist := hammingDist_le_two_of_four_matches x (q16Center highIdx lowIdx)
    q.a q.b q.c q.d hdistinct.1 hdistinct.2.1 hdistinct.2.2.1 hdistinct.2.2.2.1
    hdistinct.2.2.2.2.1 hdistinct.2.2.2.2.2 ha hb hc hd
  simpa [q16Repair, q16RepairIndex, highTarget, syndrome, highIdx, q, lowIdx] using hdist

set_option maxRecDepth 20000 in
private theorem q16Code_covers :
    CoversFinset q16Code 2 := by
  intro x
  exact ⟨q16Repair x, q16Repair_mem x, q16Repair_dist x⟩

private def q16Explicit : ExplicitQaryUpper 16 6 2 10752 :=
  { code := q16Code
    card_le := q16Code_card
    covers := q16Code_covers }

private theorem knownBoundQ16N6R2Cert :
    QaryKUpper 16 6 2 10752 :=
  q16Explicit.toUpper

def knownBoundQ16N6R2UpperName : String :=
  "lean_known_bounds_q16_n6_r2_gf8_binary_lift"

def knownBoundQ16N6R2Upper (q n r : Nat) : Nat :=
  if q = 16 ∧ n = 6 ∧ r = 2 then 10752 else trivialUpper q n r

theorem knownBoundQ16N6R2Upper_valid (q n r : Nat) :
    QaryKUpper q n r (knownBoundQ16N6R2Upper q n r) := by
  by_cases h : q = 16 ∧ n = 6 ∧ r = 2
  · rcases h with ⟨rfl, rfl, rfl⟩
    simpa [knownBoundQ16N6R2Upper] using knownBoundQ16N6R2Cert
  · simpa [knownBoundQ16N6R2Upper, h] using trivialUpper_valid q n r

