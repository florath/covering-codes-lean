private def highRepairPacked (s : Fin 512) : Nat :=
  packedHighRepairs.getD s.val 0

private def highRepairPos1 (s : Fin 512) : Fin 6 :=
  ⟨(highRepairPacked s / 384) % 6, by omega⟩

private def highRepairVal1 (s : Fin 512) : Fin 8 :=
  ⟨(highRepairPacked s / 48) % 8, by omega⟩

private def highRepairPos2 (s : Fin 512) : Fin 6 :=
  ⟨(highRepairPacked s / 8) % 6, by omega⟩

private def highRepairVal2 (s : Fin 512) : Fin 8 :=
  ⟨highRepairPacked s % 8, by omega⟩

private def highCorrection (s : Fin 512) (position : Fin 6) : Fin 8 :=
  if position = highRepairPos1 s then highRepairVal1 s
  else if position = highRepairPos2 s then highRepairVal2 s
  else 0

private def correctedHigh (x : QaryWord 8 6) (position : Fin 6) : Fin 8 :=
  gf8Add (x position) (highCorrection (highSyndrome x) position)

private def highRepairIndex (x : QaryWord 8 6) : Fin 512 :=
  ⟨(correctedHigh x 3).val * 64 + (correctedHigh x 4).val * 8 + (correctedHigh x 5).val,
    by omega⟩

private def highRepair (x : QaryWord 8 6) : QaryWord 8 6 :=
  highCenter (highRepairIndex x)

private def unpackQuad (value : Nat) : Quad6 where
